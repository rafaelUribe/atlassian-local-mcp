# Atlassian MCP — local credentials
# Copy this file to .env and fill in your values. NEVER commit .env.

# --- Jira / Confluence (same Atlassian account) ---
JIRA_HOST=your-company.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_TOKEN=your_atlassian_api_token   # https://id.atlassian.com/manage-profile/security/api-tokens

# --- Bitbucket ---
BITBUCKET_WORKSPACE=your-bitbucket-workspace-slug

# --- HTTP server (change only if 3847 is busy) ---
HTTP_PORT=3847
HTTP_BIND=0.0.0.0
