{
  "name": "atlassian-local-mcp",
  "version": "1.0.0",
  "description": "Local MCP server for Jira, Confluence and Bitbucket — AI agent workflows for dev teams",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:http": "node server.js --http 3847 --host 0.0.0.0",
    "dev:ui": "vite",
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "url": "node read-mcp.js",
    "postinstall": "node postinstall.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^2.5.3",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^4.2.19",
    "svelte-check": "^3.8.6",
    "svelte-preprocess": "^6.0.5",
    "typescript": "^5.5.4",
    "vite": "^4.5.5"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "jira",
    "confluence",
    "bitbucket",
    "atlassian",
    "ai-agents",
    "copilot"
  ],
  "license": "MIT"
}
